# Surfit production environment template
# Rotate all placeholder secrets before deploy.

SURFIT_ENV=prod
SURFIT_API_PORT=8000
SURFIT_REQUIRE_EXPLICIT_PROD_CONFIG=1

# Must be high-entropy and unique per environment.
SURFIT_TOKEN_SECRET=surfit8675309

# Required auth map (JSON object): API key -> tenant id
# Example: {"prod-key-1":"tenant_acme"}
SURFIT_API_KEYS_JSON={"live-key-1":"tenant_acme"}

# Must be explicit in prod. Avoid tenant_demo.
SURFIT_DEFAULT_TENANT_ID=tenant_acme

# Database + cache
POSTGRES_DB=surfit
POSTGRES_USER=surfit
POSTGRES_PASSWORD=#Dummypasswordsb129!
DATABASE_URL=postgresql://surfit:%23Dummypasswordsb129%21@postgres:5432/surfit
REDIS_URL=redis://redis:6379/0

# Optional path overrides
SURFIT_POLICY_ALLOWLISTS_PATH=/app/policies/allowlists.json
SURFIT_RUNTIME_ARTIFACTS_ROOT=/app/artifacts
