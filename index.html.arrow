        <div class="flow-node-icon icon-green">✓</div>
        <div class="flow-node-label">Commit</div>
        <div class="flow-node-sub">Policy-bound</div>
      </div>
      <div class="flow-arrow">→</div>
      <div class="flow-node">
        <div class="flow-node-icon icon-blue">🔒</div>
        <div class="flow-node-label">Execution Receipt</div>
        <div class="flow-node-sub">Integrity-checked</div>
      </div>
