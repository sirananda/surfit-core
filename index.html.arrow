<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Surfit.AI — Control Layer for Agent Actions</title>
<meta name="description" content="Agents can act. Surfit makes sure those actions are correct, controlled, and aligned with your business. Control and route AI actions across Slack, GitHub, X, and more.">
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 68'><path d='M0 16 C22 4,44 0,60 6 C76 12,98 22,120 10 L120 20 C98 32,76 22,60 16 C44 10,22 14,0 26 Z' fill='%2326c0ff'/><path d='M0 32 C22 20,44 16,60 22 C76 28,98 38,120 26 L120 36 C98 48,76 38,60 32 C44 26,22 30,0 42 Z' fill='%2326c0ff'/><path d='M0 48 C22 36,44 32,60 38 C76 44,98 54,120 42 L120 52 C98 64,76 54,60 48 C44 42,22 46,0 58 Z' fill='%2326c0ff'/></svg>">
<link href="https://fonts.googleapis.com/css2?family=Righteous&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --blue:    #26c0ff;
  --orange:  #ff731e;
  --dark:    #0b1220;
  --darker:  #070d18;
  --surface: #111d30;
  --border:  #1e3050;
  --text:    #e2eaf5;
  --muted:   #7a9ab8;
}

html { scroll-behavior: smooth; }

body {
  background: var(--dark);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-weight: 400;
  line-height: 1.6;
  overflow-x: hidden;
}

::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--darker); }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

/* ── NAV ── */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding: 0 48px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid rgba(30,48,80,0.6);
  background: rgba(7,13,24,0.9);
  backdrop-filter: blur(12px);
}

.nav-logo { display: flex; align-items: center; gap: 12px; text-decoration: none; }

.nav-wordmark {
  font-family: 'Righteous', cursive;
  font-size: 20px;
  line-height: 1;
  display: flex;
  align-items: baseline;
}
.nav-wordmark .s { color: var(--blue); }
.nav-wordmark .d { color: var(--muted); font-size: 14px; margin: 0 1px; }
.nav-wordmark .a { color: var(--orange); }

.nav-links { display: flex; align-items: center; gap: 32px; list-style: none; }
.nav-links a { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 0.2s; }
.nav-links a:hover { color: var(--text); }
.nav-cta { padding: 8px 20px; background: var(--blue); color: var(--dark) !important; font-weight: 600 !important; border-radius: 6px; }
.nav-cta:hover { box-shadow: 0 0 20px rgba(38,192,255,0.4) !important; }

.nav-links a.nav-link-btn {
  padding: 8px 14px;
  border-radius: 7px;
  border: 1px solid transparent;
  font-weight: 600;
}
.nav-links a.nav-link-btn.visualization {
  color: var(--blue);
  background: rgba(38,192,255,0.14);
  border-color: rgba(38,192,255,0.42);
}
.nav-links a.nav-link-btn.visualization:hover {
  color: #bfeaff;
  box-shadow: 0 0 16px rgba(38,192,255,0.25);
}
.nav-links a.nav-link-btn.demos {
  color: var(--orange);
  background: rgba(255,115,30,0.14);
  border-color: rgba(255,115,30,0.42);
}
.nav-links a.nav-link-btn.demos:hover {
  color: #ffd1b0;
  box-shadow: 0 0 16px rgba(255,115,30,0.25);
}

/* ── HERO ── */
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 104px 48px 68px;
  position: relative;
  overflow: hidden;
}

.hero-glow {
  position: absolute;
  top: 25%;
  left: 50%;
  transform: translateX(-50%);
  width: 800px;
  height: 400px;
  background: radial-gradient(ellipse, rgba(38,192,255,0.05) 0%, transparent 70%);
  pointer-events: none;
}

.hero-inner {
  max-width: 900px;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 16px;
  border: 1px solid rgba(38,192,255,0.25);
  border-radius: 100px;
  background: rgba(38,192,255,0.06);
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--blue);
  margin-bottom: 12px;
}

.hero-badge-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--blue);
  animation: pulse 2s ease infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.hero-saw-def {
  font-size: 12px;
  letter-spacing: 0.08em;
  color: #9fbfdc;
  margin: 0 auto 10px;
  max-width: 900px;
  line-height: 1.7;
}

.hero-wordmark {
  font-family: var(--surfit-display-font, 'Righteous', cursive);
  font-size: clamp(64px, 10vw, 120px);
  line-height: 0.95;
  letter-spacing: -0.01em;
  margin-bottom: 24px;
}
.hero-wordmark .s { color: var(--blue); }
.hero-wordmark .d { color: var(--muted); margin: 0 4px; font-size: 0.65em; vertical-align: middle; }
.hero-wordmark .a { color: var(--orange); }

.hero-tagline {
  font-size: clamp(13px, 1.5vw, 15px);
  font-weight: 400;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #b6d9f3;
  margin-bottom: 14px;
}

.hero-substrate {
  font-size: 15px;
  font-weight: 400;
  color: #c8e2f5;
  opacity: 0.9;
  margin-bottom: 16px;
  letter-spacing: 0.04em;
}

.hero-desc {
  font-size: clamp(16px, 2vw, 20px);
  font-weight: 300;
  color: var(--text);
  max-width: 600px;
  line-height: 1.7;
  margin-bottom: 48px;
}
.hero-desc strong { color: var(--blue); font-weight: 500; }

.hero-actions {
  display: flex;
  gap: 16px;
  align-items: center;
  flex-wrap: wrap;
  justify-content: center;
  margin-bottom: 64px;
}

.btn-primary {
  padding: 14px 32px;
  background: var(--blue);
  color: var(--dark);
  font-family: 'DM Sans', sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: box-shadow 0.2s, transform 0.2s;
}
.btn-primary:hover { box-shadow: 0 8px 32px rgba(38,192,255,0.35); transform: translateY(-1px); }

.btn-ghost {
  padding: 14px 32px;
  background: transparent;
  color: var(--muted);
  font-family: 'DM Sans', sans-serif;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  border: 1px solid var(--border);
  border-radius: 8px;
  cursor: pointer;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: border-color 0.2s, color 0.2s;
}
.btn-ghost:hover { border-color: var(--muted); color: var(--text); }

.hero-request {
  border-color: rgba(38,192,255,0.55) !important;
  color: #bfeaff !important;
  background: rgba(38,192,255,0.10) !important;
  box-shadow: 0 6px 22px rgba(38,192,255,0.18);
}
.hero-request:hover {
  border-color: rgba(38,192,255,0.78) !important;
  color: #e6f6ff !important;
  background: rgba(38,192,255,0.16) !important;
}

.hero-metrics {
  display: flex;
  gap: 0;
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  width: 100%;
  max-width: 700px;
}

.hero-metric {
  flex: 1;
  padding: 24px 28px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  border-right: 1px solid var(--border);
  background: var(--surface);
}
.hero-metric:last-child { border-right: none; }

.hero-metric-val {
  font-size: 28px;
  font-weight: 300;
  color: var(--blue);
  line-height: 1;
}
.hero-metric-val.orange { color: var(--orange); }
.hero-metric-val.white { color: var(--text); }

.hero-metric-label {
  font-size: 10px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--muted);
}

/* ── SHARED ── */
section { padding: 100px 48px; position: relative; }

.container { max-width: 1160px; margin: 0 auto; }

.section-label {
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--orange);
  margin-bottom: 16px;
}

.section-title {
  font-family: var(--surfit-display-font, 'Righteous', cursive);
  font-size: clamp(28px, 4vw, 48px);
  line-height: 1.1;
  color: var(--text);
  margin-bottom: 16px;
}

.brand-heading {
  font-family: var(--surfit-display-font, 'Righteous', cursive) !important;
  font-weight: 400 !important;
  letter-spacing: 0.01em !important;
}

.section-body {
  font-size: 15px;
  font-weight: 300;
  color: var(--muted);
  line-height: 1.8;
  max-width: 560px;
}

/* ── THESIS ── */
.thesis {
  background: var(--darker);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.thesis-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}

.thesis-statement {
  font-family: 'Righteous', cursive;
  font-size: clamp(24px, 3vw, 40px);
  line-height: 1.2;
  color: var(--text);
  margin-bottom: 24px;
}
.accent-blue { color: var(--blue); }
.accent-orange { color: var(--orange); }

.thesis-right { display: flex; flex-direction: column; gap: 24px; }

.thesis-point { display: flex; gap: 16px; align-items: flex-start; }

.thesis-point-icon {
  width: 32px; height: 32px;
  border-radius: 8px;
  background: rgba(38,192,255,0.08);
  border: 1px solid rgba(38,192,255,0.2);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  margin-top: 2px;
}
.thesis-point-icon.orange {
  background: rgba(255,115,30,0.08);
  border-color: rgba(255,115,30,0.2);
}

.thesis-point-text strong { display: block; font-size: 14px; font-weight: 500; color: var(--text); margin-bottom: 4px; }
.thesis-point-text p { font-size: 13px; font-weight: 300; color: var(--muted); line-height: 1.6; }

/* ── METRICS ── */
.metrics-section {
  background: var(--dark);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.metrics-header { text-align: center; margin-bottom: 48px; }
.metrics-header .section-body { margin: 12px auto 0; text-align: center; }

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.metric-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 28px 24px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.metric-val {
  font-size: 36px;
  font-weight: 300;
  color: var(--blue);
  line-height: 1;
}
.metric-val.orange { color: var(--orange); }
.metric-val.white { color: var(--text); }

.metric-lbl { font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); }
.metric-desc { font-size: 12px; font-weight: 300; color: var(--muted); line-height: 1.6; margin-top: 4px; }

/* ── FLOW ── */
.flow-section {
  background: var(--darker);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.flow-header { text-align: center; margin-bottom: 56px; }
.flow-header .section-body { margin: 12px auto 0; text-align: center; }

.flow-diagram {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 0;
  max-width: 960px;
  margin: 0 auto;
}

.flow-node {
  display: flex; flex-direction: column; align-items: center; gap: 10px;
  padding: 20px 18px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  min-width: 120px;
  transition: border-color 0.2s, background 0.2s;
}
.flow-node:hover { border-color: rgba(38,192,255,0.4); background: #152030; }
.flow-node.approval { border-color: rgba(255,115,30,0.35); }
.flow-node.approval:hover { border-color: rgba(255,115,30,0.6); }

.flow-node-icon {
  width: 34px; height: 34px;
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 15px;
}
.icon-blue { background: rgba(38,192,255,0.1); }
.icon-orange { background: rgba(255,115,30,0.1); }
.icon-green { background: rgba(34,197,94,0.1); }

.flow-node-label { font-size: 11px; font-weight: 500; color: var(--text); text-align: center; }
.flow-node-sub { font-size: 10px; color: var(--muted); text-align: center; text-transform: uppercase; letter-spacing: 0.06em; }

.flow-arrow { color: var(--border); font-size: 18px; padding: 0 8px; flex-shrink: 0; }

/* ── ARCHITECTURE ── */
.arch-section { background: var(--dark); }

.arch-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  margin-top: 48px;
}

.arch-card {
  background: var(--surface);
  padding: 32px 28px;
  display: flex; flex-direction: column; gap: 14px;
  transition: background 0.2s;
}
.arch-card:hover { background: #152030; }

.arch-card-num { font-family: 'Righteous', cursive; font-size: 11px; letter-spacing: 0.2em; color: var(--border); }
.arch-card-title { font-size: 15px; font-weight: 500; color: var(--text); }
.arch-card-body { font-size: 13px; font-weight: 300; color: var(--muted); line-height: 1.7; }

.arch-card-tag {
  display: inline-flex;
  padding: 4px 10px;
  border-radius: 4px;
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  width: fit-content;
}
.tag-blue { background: rgba(38,192,255,0.08); color: var(--blue); border: 1px solid rgba(38,192,255,0.2); }
.tag-orange { background: rgba(255,115,30,0.08); color: var(--orange); border: 1px solid rgba(255,115,30,0.2); }
.tag-muted { background: rgba(122,154,184,0.08); color: var(--muted); border: 1px solid rgba(122,154,184,0.2); }

/* ── CTA ── */
.cta-section {
  text-align: center;
  padding: 120px 48px;
  background: var(--darker);
  border-top: 1px solid var(--border);
}

.cta-glow {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 600px; height: 300px;
  background: radial-gradient(ellipse, rgba(38,192,255,0.04) 0%, transparent 70%);
  pointer-events: none;
}

.cta-section .section-title { max-width: 640px; margin: 0 auto 16px; }
.cta-section .section-body { max-width: 480px; margin: 0 auto 40px; text-align: center; }

.cta-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

/* ── FOOTER ── */
footer {
  border-top: 1px solid var(--border);
  padding: 40px 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--darker);
}

.footer-copy { font-size: 12px; color: var(--muted); opacity: 0.5; margin-top: 8px; }

.footer-links { display: flex; gap: 24px; list-style: none; }
.footer-links a { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); text-decoration: none; opacity: 0.5; transition: opacity 0.2s; }
.footer-links a:hover { opacity: 1; }

.runtime-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
}

.runtime-grid.demos-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  max-width: 860px;
  margin-left: auto;
  margin-right: auto;
}

.demos-framing { margin-top: 8px; }

.demo-subsection { margin-top: 28px; }

.demo-subsection-title {
  font-size: 18px;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 8px;
}

.demo-subsection-intro {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.7;
}

.core-row-1 {
  margin-top: 18px;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
}

.core-row-2 {
  margin-top: 14px;
  display: flex;
  justify-content: center;
  gap: 14px;
  flex-wrap: wrap;
}

.core-row-2 .demo-card {
  width: 100%;
  max-width: 318px;
}

.foundation-grid {
  margin-top: 18px;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
}

.demo5-center-wrap {
  display: flex;
  justify-content: center;
  margin-top: 14px;
}

.demo5-center-wrap .demo-card {
  width: 100%;
  max-width: 423px;
}

.teams-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.teams-grid .full-span {
  grid-column: 1 / -1;
}

.runtime-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 20px 18px;
}

.demo-card {
  display: flex;
  flex-direction: column;
}

.demo-card p {
  flex: 1;
}

.demo-card-action {
  margin-top: 14px;
}

.btn-demo-orange {
  background: var(--orange);
}

.btn-demo-orange:hover {
  box-shadow: 0 8px 32px rgba(255,115,30,0.35) !important;
}

.runtime-card-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}

.runtime-icon {
  width: 26px;
  height: 26px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 7px;
  border: 1px solid rgba(38,192,255,0.35);
  background: rgba(38,192,255,0.08);
  color: var(--blue);
}

.runtime-card h4 {
  font-size: 14px;
  font-weight: 500;
  color: var(--text);
}

.runtime-card p {
  font-size: 13px;
  font-weight: 300;
  color: var(--muted);
  line-height: 1.7;
}

.runtime-outcome {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--border);
  font-size: 12px;
  color: var(--text);
}

.faq-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
}

.faq-item {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 16px 18px;
}

.faq-item h4 {
  font-size: 14px;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 8px;
}

.faq-item p {
  font-size: 13px;
  font-weight: 300;
  color: var(--muted);
  line-height: 1.7;
}

.progress-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
  margin-top: 26px;
}

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  nav { padding: 0 24px; }
  .nav-links { display: none; }
  section { padding: 72px 24px; }
  .thesis-grid { grid-template-columns: 1fr; gap: 40px; }
  .arch-grid { grid-template-columns: 1fr; }
  .metrics-grid { grid-template-columns: 1fr 1fr; }
  .runtime-grid { grid-template-columns: 1fr 1fr; }
  .core-row-1 { grid-template-columns: 1fr 1fr; }
  .foundation-grid { grid-template-columns: 1fr; }
  .teams-grid { grid-template-columns: 1fr; }
  .progress-grid { grid-template-columns: 1fr; }
  footer { flex-direction: column; gap: 24px; text-align: center; }
  .hero { padding: 100px 24px 60px; }
}

@media (max-width: 600px) {
  .metrics-grid { grid-template-columns: 1fr; }
  .hero-metrics { flex-direction: column; }
  .hero-metric { border-right: none; border-bottom: 1px solid var(--border); }
  .hero-metric:last-child { border-bottom: none; }
  .cta-actions { flex-direction: column; align-items: center; }
  .flow-diagram { gap: 8px; }
  .runtime-grid { grid-template-columns: 1fr; }
  .core-row-1 { grid-template-columns: 1fr; }
  .core-row-2 { flex-direction: column; align-items: stretch; }
  .core-row-2 .demo-card { max-width: none; }
  .foundation-grid { grid-template-columns: 1fr; }
  .teams-grid { grid-template-columns: 1fr; }
}
</style>
<style id="surfit-display-font-override">
