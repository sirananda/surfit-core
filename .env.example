# Surfit runtime environment
SURFIT_ENV=prod
SURFIT_API_PORT=8000

# Core service URLs
DATABASE_URL=postgresql://surfit:surfit_change_me@postgres:5432/surfit
REDIS_URL=redis://redis:6379/0

# Optional Postgres bootstrap variables used by docker compose
POSTGRES_DB=surfit
POSTGRES_USER=surfit
POSTGRES_PASSWORD=surfit_change_me
